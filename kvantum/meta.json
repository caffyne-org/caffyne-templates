{
  "id": "kvantum",
  "name": "QT (Kvantum)",
  "description": "Kvantum theme engine colors",
  "notes": "Colors for kvantum with transparency\n\nTo apply manually:\n • Launch <tt><i>kvantum-manager</i></tt>\n \n • Select <tt><i>matugen</i></tt> from the themes tab \n • Select <tt><i>kvantum</i></tt> as the style in qt5/qt6ct",
  "templates": [
    {
      "id": "kvantum_kvconfig",
      "input_path": "template.kvconfig",
      "output_path": "~/.config/Kvantum/matugen/matugen.kvconfig"
    },
    {
      "id": "kvantum_svg",
      "input_path": "template.svg",
      "output_path": "~/.config/Kvantum/matugen/matugen.svg",
      "post_hook_script": "post_hook.sh"
    }
  ]
}